"                <th>любой заголовок для значения свойства</th>\n"
"            </tr>\n"
"            <tr>\n"
"                <td>артикул-1</td>\n"
"                <td>бла-бла</td>\n"
"                <td>777</td>\n"
"                <td>бла-бла1</td>\n"
"                <td>7779</td>\n"
"                <td>бла-бла2</td>\n"
"                <td>7773</td>\n"
"            </tr>\n"
"        </tbody>\n"
